{
  "name": "@opspilot/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "OpsPilot 백엔드 (Fastify + Zod + better-sqlite3).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json && mkdir -p dist/domains/harness-bridge/hooks && cp src/domains/harness-bridge/hooks/*.mjs dist/domains/harness-bridge/hooks/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts",
    "sync:agent-crew": "tsx src/domains/agent-crew/sync-cli.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opspilot/shared-types": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opspilot/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
